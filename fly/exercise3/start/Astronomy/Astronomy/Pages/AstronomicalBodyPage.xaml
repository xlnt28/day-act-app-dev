<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="Astronomy.Pages.AstronomicalBodyPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Astronomical Data"
    BackgroundColor="#020617">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IconOverride="comet.png" />
    </Shell.BackButtonBehavior>

    <Grid>
        <Image
            Source="starfield.png"
            Aspect="AspectFill"
            Opacity="0.45" />

        <BoxView Color="#020617" Opacity="0.62" />

        <ScrollView>
            <Grid Padding="24" RowSpacing="22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 32"
                    Padding="28">

                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1E1B4B" Offset="0.0" />
                            <GradientStop Color="#6D28D9" Offset="0.55" />
                            <GradientStop Color="#EC4899" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label
                            x:Name="lblIcon"
                            FontSize="96"
                            HorizontalOptions="Center"
                            TextColor="White" />

                        <Label
                            x:Name="lblName"
                            FontSize="30"
                            FontAttributes="Bold"
                            HorizontalTextAlignment="Center"
                            TextColor="White" />

                        <Label
                            Text="Deep-space profile"
                            FontSize="14"
                            HorizontalTextAlignment="Center"
                            TextColor="#FCE7F3" />
                    </VerticalStackLayout>
                </Border>

                <Border
                    Grid.Row="1"
                    Stroke="#334155"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 26"
                    BackgroundColor="#0F172A"
                    Padding="20">

                    <Grid RowSpacing="18" ColumnSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Label
                            Grid.Row="0"
                            Grid.Column="0"
                            Text="Mass"
                            FontSize="15"
                            FontAttributes="Bold"
                            TextColor="#38BDF8" />

                        <Label
                            x:Name="lblMass"
                            Grid.Row="0"
                            Grid.Column="1"
                            FontSize="15"
                            TextColor="#F8FAFC" />

                        <Label
                            Grid.Row="1"
                            Grid.Column="0"
                            Text="Circumference"
                            FontSize="15"
                            FontAttributes="Bold"
                            TextColor="#38BDF8" />

                        <Label
                            x:Name="lblCircumference"
                            Grid.Row="1"
                            Grid.Column="1"
                            FontSize="15"
                            TextColor="#F8FAFC" />

                        <Label
                            Grid.Row="2"
                            Grid.Column="0"
                            Text="Age"
                            FontSize="15"
                            FontAttributes="Bold"
                            TextColor="#38BDF8" />

                        <Label
                            x:Name="lblAge"
                            Grid.Row="2"
                            Grid.Column="1"
                            FontSize="15"
                            TextColor="#F8FAFC" />
                    </Grid>
                </Border>

                <Border
                    Grid.Row="2"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 22"
                    BackgroundColor="#111827"
                    Padding="18">

                    <Label
                        Text="This page receives its selected body through a Shell query parameter."
                        FontSize="13"
                        TextColor="#CBD5E1"
                        HorizontalTextAlignment="Center" />
                </Border>
            </Grid>
        </ScrollView>
    </Grid>

</ContentPage>