<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Astronomy.Pages.SunrisePage"
             Title="Sunrise">
    <Grid RowDefinitions="Auto,*" Padding="20" BackgroundColor="#F6F7F9">
        <VerticalStackLayout Spacing="4" Margin="0,8,0,16">
            <Label Text="Sun schedule" FontAttributes="Bold" FontSize="24" TextColor="#1F2937" />
            <Label x:Name="lblDate" FontSize="14" TextColor="#6B7280" />
        </VerticalStackLayout>

        <Frame Grid.Row="1"
               Padding="20"
               CornerRadius="20"
               BorderColor="#E5E7EB"
               BackgroundColor="White"
               HasShadow="False">
            <VerticalStackLayout Spacing="18">
                <ActivityIndicator x:Name="activityWaiting"
                                   IsRunning="False"
                                   Color="#374151"
                                   HorizontalOptions="Center" />

                <Grid ColumnDefinitions="Auto,*"
                      RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="14"
                      ColumnSpacing="12">
                    <Label Grid.Row="0" Text="🌅" FontSize="30" />
                    <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="2">
                        <Label Text="Sunrise" FontAttributes="Bold" TextColor="#111827" />
                        <Label x:Name="lblSunrise" FontSize="16" TextColor="#374151" />
                    </VerticalStackLayout>

                    <Label Grid.Row="1" Text="☀️" FontSize="30" />
                    <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="2">
                        <Label Text="Daylight" FontAttributes="Bold" TextColor="#111827" />
                        <Label x:Name="lblDaylight" FontSize="16" TextColor="#374151" />
                    </VerticalStackLayout>

                    <Label Grid.Row="2" Text="🌇" FontSize="30" />
                    <VerticalStackLayout Grid.Row="2" Grid.Column="1" Spacing="2">
                        <Label Text="Sunset" FontAttributes="Bold" TextColor="#111827" />
                        <Label x:Name="lblSunset" FontSize="16" TextColor="#374151" />
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentPage>
