<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Astronomy.Pages.MoonPhasePage"
             Title="Moon Phase"
             BackgroundColor="#F6F7F9">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">
            <VerticalStackLayout Spacing="4">
                <Label Text="Moon phase" FontAttributes="Bold" FontSize="24" TextColor="#1F2937" />
                <Label x:Name="lblDate" FontSize="14" TextColor="#6B7280" />
            </VerticalStackLayout>

            <Frame Padding="20"
                   CornerRadius="20"
                   BorderColor="#E5E7EB"
                   BackgroundColor="White"
                   HasShadow="False">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label x:Name="lblMoonPhaseIcon" FontSize="84" HorizontalTextAlignment="Center" />
                    <Label x:Name="lblMoonPhaseText"
                           FontAttributes="Bold"
                           FontSize="20"
                           TextColor="#111827"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Frame>

            <Label Text="Next 4 days"
                   FontAttributes="Bold"
                   FontSize="16"
                   TextColor="#374151" />

            <Grid ColumnDefinitions="*,*"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="12"
                  ColumnSpacing="12">
                <Frame Grid.Row="0" Grid.Column="0" Padding="14" CornerRadius="16" BorderColor="#E5E7EB" BackgroundColor="White" HasShadow="False">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Label x:Name="lblPhaseIcon1" FontSize="44" HorizontalTextAlignment="Center" />
                        <Label x:Name="lblPhaseText1" FontSize="14" FontAttributes="Bold" TextColor="#374151" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="0" Grid.Column="1" Padding="14" CornerRadius="16" BorderColor="#E5E7EB" BackgroundColor="White" HasShadow="False">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Label x:Name="lblPhaseIcon2" FontSize="44" HorizontalTextAlignment="Center" />
                        <Label x:Name="lblPhaseText2" FontSize="14" FontAttributes="Bold" TextColor="#374151" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="1" Grid.Column="0" Padding="14" CornerRadius="16" BorderColor="#E5E7EB" BackgroundColor="White" HasShadow="False">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Label x:Name="lblPhaseIcon3" FontSize="44" HorizontalTextAlignment="Center" />
                        <Label x:Name="lblPhaseText3" FontSize="14" FontAttributes="Bold" TextColor="#374151" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="1" Grid.Column="1" Padding="14" CornerRadius="16" BorderColor="#E5E7EB" BackgroundColor="White" HasShadow="False">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Label x:Name="lblPhaseIcon4" FontSize="44" HorizontalTextAlignment="Center" />
                        <Label x:Name="lblPhaseText4" FontSize="14" FontAttributes="Bold" TextColor="#374151" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
