<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Phoneword.MainPage"
             Title="Phoneword"
             BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}">
    <ContentPage.Resources>
        <Style x:Key="SecondaryActionButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}" />
            <Setter Property="BorderWidth" Value="1" />
            <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray500}}" />
        </Style>

        <Style x:Key="PrimaryActionButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}" />
        </Style>
    </ContentPage.Resources>

    <Grid Padding="20">
        <VerticalStackLayout Spacing="14"
                             MaximumWidthRequest="460"
                             HorizontalOptions="Center"
                             VerticalOptions="Center">
            <Label Text="Phoneword"
                   FontSize="30"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray100}}" />

            <Label Text="Translate text into a dialable number."
                   FontSize="14"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />

            <Border BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1"
                    Padding="18"
                    StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Phone input"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                                StrokeThickness="0"
                                Padding="10,4"
                                StrokeShape="RoundRectangle 10">
                            <Entry x:Name="PhoneNumberText"
                                   Text="1-555-NETMAUI"
                                   Placeholder="Enter a phoneword"
                                   ClearButtonVisibility="WhileEditing"
                                   FontSize="16" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Examples"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="8">
                            <Label Text="•"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                            <Label Grid.Column="1"
                                   Text="1-800-FLOWERS"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray800}, Dark={StaticResource Gray100}}" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="8">
                            <Label Text="•"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                            <Label Grid.Column="1"
                                   Text="1-555-NETMAUI"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray800}, Dark={StaticResource Gray100}}" />
                        </Grid>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button x:Name="TranslateButton"
                                Grid.Column="0"
                                Style="{StaticResource SecondaryActionButton}"
                                Text="Translate"
                                Clicked="OnTranslate" />

                        <Button x:Name="CallButton"
                                Grid.Column="1"
                                Style="{StaticResource PrimaryActionButton}"
                                Text="Call"
                                IsEnabled="False"
                                Clicked="OnCall" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
