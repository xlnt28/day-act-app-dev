<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Phoneword.MainPage"
             Title="Phoneword"
             BackgroundColor="#F3F6FF">

    <ScrollView>
        <VerticalStackLayout Padding="20,24" Spacing="16">
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 26"
                    Padding="20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1D4ED8" Offset="0.0" />
                        <GradientStop Color="#7C3AED" Offset="0.55" />
                        <GradientStop Color="#DB2777" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Phoneword"
                           FontSize="32"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="Turn words into dialable numbers instantly."
                           FontSize="14"
                           TextColor="#FCE7F3" />
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24"
                    Padding="16">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Enter phoneword"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#1E293B" />

                    <Border BackgroundColor="#F8FAFF"
                            Stroke="#DDE4FF"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="12,6">
                        <Entry x:Name="PhoneNumberText"
                               Text="1-555-NETMAUI"
                               Placeholder="Enter a phoneword"
                               ClearButtonVisibility="WhileEditing"
                               FontSize="17"
                               TextColor="#0F172A"
                               PlaceholderColor="#9AA5BF" />
                    </Border>

                    <Label x:Name="resultLabel"
                           Text="Ready to translate"
                           FontSize="13"
                           TextColor="#64748B" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button x:Name="TranslateButton"
                                Grid.Column="0"
                                Text="Translate"
                                Clicked="OnTranslate"
                                BackgroundColor="#EEF2FF"
                                BorderColor="#D8E0FF"
                                BorderWidth="1"
                                TextColor="#4338CA"
                                FontAttributes="Bold"
                                CornerRadius="14" />

                        <Button x:Name="CallButton"
                                Grid.Column="1"
                                Text="Call"
                                IsEnabled="False"
                                Clicked="OnCall"
                                BackgroundColor="#1E293B"
                                TextColor="White"
                                FontAttributes="Bold"
                                CornerRadius="14" />
                    </Grid>

                    <Border BackgroundColor="#F8FAFF"
                            Stroke="#E2E8F0"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="12">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Try examples"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#475569" />
                            <Label Text="• 1-800-FLOWERS" FontSize="13" TextColor="#334155" />
                            <Label Text="• 1-888-NEW-CARS" FontSize="13" TextColor="#334155" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
