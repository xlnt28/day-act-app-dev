<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MovieCatalog.ViewModels"
             x:Class="MovieCatalog.Views.MovieDetailPage"
             x:DataType="vm:MovieViewModel"
             Title="Movie"
             BackgroundColor="#F5F7FC">
    <ScrollView>
        <VerticalStackLayout Padding="18,20" Spacing="14">
            <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 24" Padding="18">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding Title}"
                           FontSize="30"
                           FontAttributes="Bold"
                           TextColor="#172033" />
                    <Label Text="{Binding Year, StringFormat='Released {0:yyyy}'}"
                           FontSize="14"
                           TextColor="#5E6C84" />
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 24" Padding="18">
                <VerticalStackLayout Spacing="16">
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Border BackgroundColor="#F6F8FF" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="12">
                            <VerticalStackLayout Spacing="3">
                                <Label Text="STUDIO" FontSize="12" TextColor="#718096" />
                                <Label Text="{Binding Studio}" FontSize="18" FontAttributes="Bold" TextColor="#111A2E" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1" BackgroundColor="#F6F8FF" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="12">
                            <VerticalStackLayout Spacing="3">
                                <Label Text="DIRECTOR" FontSize="12" TextColor="#718096" />
                                <Label Text="{Binding Director}" FontSize="18" FontAttributes="Bold" TextColor="#111A2E" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
