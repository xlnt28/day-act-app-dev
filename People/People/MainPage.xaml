<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="People.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#101828">

    <Grid RowDefinitions="Auto,*" Padding="24">

        <VerticalStackLayout Spacing="8" Margin="0,20,0,24">
            <Label
                Text="People Vault"
                FontSize="34"
                FontAttributes="Bold"
                TextColor="White" />

            <Label
                Text="Save names locally with SQLite"
                FontSize="15"
                TextColor="#98A2B3" />
        </VerticalStackLayout>

        <Border
            Grid.Row="1"
            StrokeThickness="0"
            BackgroundColor="#1D2939"
            Padding="22"
            StrokeShape="RoundRectangle 28">

            <VerticalStackLayout Spacing="18">

                <Border
                    Stroke="#344054"
                    StrokeThickness="1"
                    BackgroundColor="#111827"
                    Padding="14"
                    StrokeShape="RoundRectangle 18">

                    <Entry
                        x:Name="newPerson"
                        Placeholder="Enter a name"
                        PlaceholderColor="#667085"
                        TextColor="White"
                        FontSize="16"
                        ClearButtonVisibility="WhileEditing" />
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button
                        Text="Add Person"
                        Clicked="OnNewButtonClicked"
                        BackgroundColor="#7C3AED"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="18"
                        HeightRequest="52" />

                    <Button
                        Grid.Column="1"
                        Text="Show All"
                        Clicked="OnGetButtonClicked"
                        BackgroundColor="#06B6D4"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="18"
                        HeightRequest="52" />
                </Grid>

                <Label
                    x:Name="statusMessage"
                    TextColor="#A7F3D0"
                    FontSize="14"
                    HorizontalTextAlignment="Center" />

                <Label
                    Text="Saved People"
                    TextColor="White"
                    FontSize="20"
                    FontAttributes="Bold"
                    Margin="0,8,0,0" />

                <CollectionView
                    x:Name="peopleList"
                    SelectionMode="None">

                    <CollectionView.EmptyView>
                        <VerticalStackLayout Padding="20" Spacing="8">
                            <Label
                                Text="No people saved yet"
                                TextColor="#98A2B3"
                                FontSize="16"
                                HorizontalTextAlignment="Center" />
                            <Label
                                Text="Add a name above to get started."
                                TextColor="#667085"
                                FontSize="13"
                                HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,6"
                                Padding="16"
                                BackgroundColor="#111827"
                                Stroke="#344054"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 18">

                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                                    <Border
                                        WidthRequest="42"
                                        HeightRequest="42"
                                        BackgroundColor="#7C3AED"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 21">

                                        <Label
                                            Text="👤"
                                            FontSize="20"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <Label
                                            Text="{Binding Name}"
                                            TextColor="White"
                                            FontSize="17"
                                            FontAttributes="Bold" />

                                        <Label
                                            Text="{Binding Id, StringFormat='ID #{0}'}"
                                            TextColor="#98A2B3"
                                            FontSize="12" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>