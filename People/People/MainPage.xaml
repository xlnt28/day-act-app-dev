<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="People.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#0B1220">

    <Grid RowDefinitions="Auto,*" Padding="20,24,20,20" RowSpacing="14">

        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <VerticalStackLayout Spacing="4">
                <Label
                    Text="People"
                    FontSize="30"
                    FontAttributes="Bold"
                    TextColor="#F8FAFC" />

                <Label
                    Text="Minimal local contacts"
                    FontSize="14"
                    TextColor="#94A3B8" />
            </VerticalStackLayout>

            <Border
                Grid.Column="1"
                Padding="12,8"
                BackgroundColor="#111A2D"
                Stroke="#24324B"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 14"
                VerticalOptions="Start">
                <Label
                    Text="SQLite"
                    FontSize="12"
                    TextColor="#93C5FD"
                    FontAttributes="Bold" />
            </Border>
        </Grid>

        <Border
            Grid.Row="1"
            StrokeThickness="1"
            Stroke="#1F2A44"
            BackgroundColor="#0F172A"
            Padding="16"
            StrokeShape="RoundRectangle 20">

            <VerticalStackLayout Spacing="14">

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <Border
                        Stroke="#24324B"
                        StrokeThickness="1"
                        BackgroundColor="#111A2D"
                        Padding="12,10"
                        StrokeShape="RoundRectangle 14">

                        <Entry
                            x:Name="newPerson"
                            Placeholder="Type a name"
                            PlaceholderColor="#64748B"
                            TextColor="#E2E8F0"
                            FontSize="15"
                            ClearButtonVisibility="WhileEditing" />
                    </Border>

                    <Button
                        Grid.Column="1"
                        Text="Add"
                        Clicked="OnNewButtonClicked"
                        BackgroundColor="#2563EB"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="14"
                        Padding="18,0"
                        HeightRequest="46" />
                </Grid>

                <Button
                    Text="Refresh List"
                    Clicked="OnGetButtonClicked"
                    BackgroundColor="#1E293B"
                    TextColor="#CBD5E1"
                    BorderColor="#334155"
                    BorderWidth="1"
                    FontAttributes="Bold"
                    CornerRadius="14"
                    HeightRequest="42" />

                <Label
                    x:Name="statusMessage"
                    TextColor="#86EFAC"
                    FontSize="13"
                    HorizontalTextAlignment="Center" />

                <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,0">
                    <Label
                        Text="Saved People"
                        TextColor="#F8FAFC"
                        FontSize="18"
                        FontAttributes="Bold" />

                    <Border
                        Grid.Column="1"
                        Padding="8,2"
                        BackgroundColor="#111A2D"
                        Stroke="#24324B"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 10">
                        <Label
                            Text="Local"
                            FontSize="11"
                            TextColor="#94A3B8" />
                    </Border>
                </Grid>

                <CollectionView
                    x:Name="peopleList"
                    SelectionMode="None">

                    <CollectionView.EmptyView>
                        <VerticalStackLayout Padding="18" Spacing="6">
                            <Label
                                Text="No saved people"
                                TextColor="#94A3B8"
                                FontSize="15"
                                HorizontalTextAlignment="Center" />
                            <Label
                                Text="Add a name to create your list."
                                TextColor="#64748B"
                                FontSize="12"
                                HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,4"
                                Padding="12"
                                BackgroundColor="#111A2D"
                                Stroke="#24324B"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 14">

                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <Border
                                        WidthRequest="34"
                                        HeightRequest="34"
                                        BackgroundColor="#1D4ED8"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 17">

                                        <Label
                                            Text="👤"
                                            FontSize="16"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center" />
                                    </Border>

                                    <Grid Grid.Column="1" ColumnDefinitions="*,Auto" VerticalOptions="Center">
                                        <Label
                                            Text="{Binding Name}"
                                            TextColor="#E2E8F0"
                                            FontSize="16"
                                            FontAttributes="Bold"
                                            VerticalOptions="Center" />

                                        <Label
                                            Grid.Column="1"
                                            Text="{Binding Id, StringFormat='#{0}'}"
                                            TextColor="#94A3B8"
                                            FontSize="12"
                                            VerticalOptions="Center" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
