<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:cvt="clr-namespace:WeatherClient.Converters"
             x:Class="WeatherClient.MainPage"
             BackgroundColor="#F2F4F7">

    <ContentPage.Resources>
        <cvt:WeatherConditionToImageConverter x:Key="WeatherConditionToImageConverter" />
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20,24" Spacing="16">

            <Border StrokeThickness="0"
                    BackgroundColor="#111827"
                    StrokeShape="RoundRectangle 20">
                <VerticalStackLayout Padding="20" Spacing="6">
                    <Label Text="Weather Forecast"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="White" />

                    <Label Text="Check the latest weather conditions for your area."
                           FontSize="14"
                           TextColor="#D1D5DB" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="0"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 20">
                <VerticalStackLayout Padding="18" Spacing="14">

                    <Label Text="Search Location"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#1F2937" />

                    <Label Text="Enter a postal code to load the forecast."
                           FontSize="13"
                           TextColor="#6B7280" />

                    <VerticalStackLayout Spacing="10">

                        <Entry x:Name="txtPostalCode"
                               Placeholder="Postal code"
                               Keyboard="Text"
                               BackgroundColor="#F3F4F6"
                               TextColor="#111827"
                               PlaceholderColor="#9CA3AF"
                               HeightRequest="50"
                               Margin="0" />

                        <Button x:Name="btnRefresh"
                                Text="Refresh"
                                Clicked="btnRefresh_Clicked"
                                HeightRequest="46"
                                BackgroundColor="#1F2937"
                                TextColor="White"
                                CornerRadius="12" />

                        <ActivityIndicator x:Name="actIsBusy"
                                           HorizontalOptions="Center"
                                           Margin="0,2,0,0"
                                           Color="#4B5563" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="0"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 20">
                <VerticalStackLayout Padding="18" Spacing="14">

                    <HorizontalStackLayout Spacing="12">
                        <Border StrokeThickness="0"
                                BackgroundColor="#F3F4F6"
                                StrokeShape="RoundRectangle 14"
                                Padding="10">
                            <Image HeightRequest="36"
                                   WidthRequest="36"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   Source="{Binding Condition, Converter={StaticResource WeatherConditionToImageConverter}}" />
                        </Border>

                        <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                            <Label Text="Today’s Forecast"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />
                            <Label Text="Minimal weather overview"
                                   FontSize="13"
                                   TextColor="#6B7280" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <Grid ColumnDefinitions="Auto,*"
                          RowDefinitions="Auto,Auto,Auto,Auto"
                          ColumnSpacing="8"
                          RowSpacing="10">
                        <Label Grid.Row="0"
                               Grid.Column="0"
                               Text="Temperature"
                               FontSize="13"
                               TextColor="#6B7280" />
                        <Label Grid.Row="0"
                               Grid.Column="1"
                               Text="{Binding Temperature}"
                               FontSize="18"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="End"
                               TextColor="#111827" />

                        <Label Grid.Row="1"
                               Grid.Column="0"
                               Text="Humidity"
                               FontSize="13"
                               TextColor="#6B7280" />
                        <Label Grid.Row="1"
                               Grid.Column="1"
                               Text="{Binding Humidity}"
                               FontSize="18"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="End"
                               TextColor="#111827" />

                        <Label Grid.Row="2"
                               Grid.Column="0"
                               Text="Precipitation"
                               FontSize="13"
                               TextColor="#6B7280" />
                        <Label Grid.Row="2"
                               Grid.Column="1"
                               Text="{Binding Precipitation}"
                               FontSize="18"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="End"
                               TextColor="#111827" />

                        <Label Grid.Row="3"
                               Grid.Column="0"
                               Text="Wind"
                               FontSize="13"
                               TextColor="#6B7280" />
                        <Label Grid.Row="3"
                               Grid.Column="1"
                               Text="{Binding Wind}"
                               FontSize="18"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="End"
                               TextColor="#111827" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
